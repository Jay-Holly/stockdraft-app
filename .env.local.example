NEXT_PUBLIC_SUPABASE_URL=https://tkdhgzstxclwubtzvlwc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_FINNHUB_KEY=your_finnhub_api_key_here

# Server-only — cron jobs upsert cached prices into Supabase.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Vercel Cron auth — Vercel sends `Authorization: Bearer ${CRON_SECRET}` on cron invocations.
CRON_SECRET=your_random_cron_secret_here

# Local dev only — invite links and other absolute URLs use this origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel production: set NEXT_PUBLIC_APP_URL=https://stockdraft-app.vercel.app
# in Project Settings → Environment Variables (Production), not in .env.local.
